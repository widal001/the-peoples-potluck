{
  "name": "sample-site",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "wrangler:preview": "pnpm build && wrangler dev",
    "astro": "astro",
    "astro:check": "astro check",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "checks": "pnpm lint:check && pnpm format:check && pnpm astro:check",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply resistance-potluck-db --local",
    "db:migrate:preview": "wrangler d1 migrations apply resistance-potluck-db --env preview",
    "db:migrate:prod": "wrangler d1 migrations apply resistance-potluck-db",
    "db:seed:generate": "pnpm exec tsx scripts/seed-database.ts",
    "db:seed:local": "pnpm db:seed:generate && wrangler d1 execute resistance-potluck-db --local --file=scripts/seed-data.sql",
    "db:seed:preview": "pnpm db:seed:generate && wrangler d1 execute resistance-potluck-db --env preview --file=scripts/seed-data.sql",
    "db:seed:prod": "pnpm db:seed:generate && wrangler d1 execute resistance-potluck-db --file=scripts/seed-data.sql",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/svelte": "^7.2.5",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.16.15",
    "drizzle-orm": "^0.45.1",
    "nanostores": "^1.1.0",
    "sharp": "^0.34.5",
    "svelte": "^5.48.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@cloudflare/vitest-pool-workers": "^0.12.7",
    "@cloudflare/workers-types": "^4.20250124.0",
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.1.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.5.0",
    "globals": "^16.5.0",
    "gray-matter": "^4.0.3",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.19.0",
    "typescript-eslint": "^8.53.1",
    "vitest": "~3.2.0",
    "wrangler": "^4.60.0"
  }
}
