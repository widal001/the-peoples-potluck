---
interface Props {
  title?: string;
  class?: string;
  variant?: "default" | "linocut";
}

const { title, class: className = "", variant = "default" } = Astro.props;

const baseClass = variant === "linocut" ? "card-linocut" : "card";
---

<div class={`${baseClass} ${className}`}>
  {
    title && (
      <h2 class="text-heading-3" style="margin-bottom: var(--spacing-md);">
        {title}
      </h2>
    )
  }
  <slot />
</div>
