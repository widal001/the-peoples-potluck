---
import { Image } from "astro:assets";
import DesktopNavigation from "@/components/layout/DesktopNavigation.astro";
import MobileNavigation from "@/components/layout/MobileNavigation.astro";
import logoSVG from "@/svg/logo_main.svg";
import { siteConfig } from "@/config/site";

interface NavItem {
  label: string;
  href: string;
}

interface NavDropdown {
  label: string;
  items: NavItem[];
}

interface Props {
  logoHref?: string;
  logo?: typeof logoSVG;
  items: (NavItem | NavDropdown)[];
}

const { logoHref = "/", logo, items } = Astro.props;
---

<nav
  class="bg-background border-b border-border relative transition-colors nav-theme"
  role="navigation"
  aria-label="Main navigation"
>
  <div class="container-padded">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <div class="shrink-0">
        <a href={logoHref} class="nav-logo" aria-label="Home">
          {
            logo ? (
              <Image
                src={logo}
                alt={siteConfig.companyName}
                width={142}
                height={32}
                loading="eager"
              />
            ) : (
              siteConfig.companyName
            )
          }
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex md:items-center md:space-x-4">
        <DesktopNavigation items={items} />
      </div>

      <!-- Mobile Navigation -->
      <div class="md:hidden flex items-center space-x-2">
        <MobileNavigation items={items} />
      </div>
    </div>
  </div>
</nav>

<style is:global>
  /* Navigation styles */
  .nav-theme {
    background-color: var(--background-default);
    border-bottom: var(--border-width) solid var(--border-default);
  }

  .nav-theme a,
  .nav-theme button[data-dropdown-button] {
    border-radius: var(--radius-md);
  }

  .nav-logo {
    border-radius: var(--radius-md);
    color: var(--text-color-default);
    display: inline-block;
    font-size: var(--font-size-2xl);
    font-weight: 700;
    outline: none;
    padding: var(--spacing-xs);
    text-decoration: none;
    transition: all var(--transition-normal);
  }

  .nav-logo:hover {
    color: var(--text-color-default);
    opacity: 0.8;
  }

  .nav-logo:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .nav-logo img {
    height: 2rem;
    width: auto;
    display: block;
  }

  .container-padded {
    margin-inline: auto;
    max-width: 80rem;
    padding-inline: var(--spacing-md);
  }

  @media (min-width: 640px) {
    .container-padded {
      padding-inline: var(--spacing-lg);
    }
  }

  @media (min-width: 1024px) {
    .container-padded {
      padding-inline: var(--spacing-2xl);
    }
  }
</style>
