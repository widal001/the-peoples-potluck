---
import LinkButton from "@/components/ui/LinkButton.astro";
import PotluckBanner from "@/svg/potluck_banner.svg?raw";

interface Props {
  tagline: string;
  description?: string;
  backgroundImage?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { tagline, description, ctaText, ctaHref } = Astro.props;
const hasDescriptionSlot = Astro.slots.has("description");
---

<section class="hero banner-section" id="banner">
  <div class="banner-logo-mark" set:html={PotluckBanner} aria-hidden="true" />
  <div class="container-content">
    <div class="banner-content">
      <h1 class="text-heading-1 hero-heading">
        {tagline}
      </h1>
      <p class="text-body-large hero-description">
        {hasDescriptionSlot ? <slot name="description" /> : description}
      </p>
      {ctaText && ctaHref && <LinkButton href={ctaHref} text={ctaText} />}
    </div>
  </div>
</section>

<style is:global>
  /* Hero/Banner styles */
  .hero {
    padding-block: var(--section-padding-y);
    padding-inline: var(--section-padding-x);
    text-align: center;
  }

  .hero-heading {
    color: var(--text-color-default);
    margin-bottom: var(--spacing-lg);
  }

  .hero-description {
    color: var(--text-color-default);
    margin-bottom: var(--spacing-2xl);
    opacity: 0.9;
    line-height: 1.75;
  }

  /* Banner link styles */
  .hero-description a {
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-thickness: 2px;
    transition: opacity var(--transition-normal);
  }

  .hero-description a:hover {
    opacity: 0.8;
  }

  .hero-description a:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .banner-link-primary {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .banner-section {
    background: var(--secondary-lightest);
    color: var(--text-color-default);
    position: relative;
    overflow: hidden;
  }

  /* Logo mark - hidden on mobile */
  .banner-logo-mark {
    display: none;
    pointer-events: none;
    z-index: 0;
  }

  .banner-logo-mark svg {
    width: 100%;
    height: auto;
  }

  .banner-section .container-content {
    position: relative;
    z-index: 1;
  }

  /* Tablet styles */
  @media (min-width: 768px) {
    .hero {
      min-height: 500px;
      padding-block: var(--spacing-4xl);
      padding-inline: var(--spacing-3xl);
      text-align: left;
      display: flex;
      align-items: center;
      justify-content: flex-start;
    }

    .banner-section .container-content {
      width: 100%;
    }

    .banner-content {
      max-width: 36rem;
    }

    .banner-logo-mark {
      display: block;
      position: absolute;
      bottom: -20%;
      right: 5%;
      width: 50%;
      max-width: 550px;
      opacity: 0.3;
    }
  }

  /* Larger desktop styles */
  @media (min-width: 1200px) {
    .hero {
      padding-inline: var(--section-padding-x);
    }
    .banner-logo-mark {
      opacity: 0.4;
    }
  }
</style>
