---
import PotluckCard from "./PotluckCard.astro";
import CategoryBadge from "./CategoryBadge.astro";
import type { CollectionEntry } from "astro:content";

type PotluckCollection =
  | "side-dishes"
  | "desserts"
  | "plates-cutlery"
  | "drinks";

interface PlateItem {
  item: CollectionEntry<PotluckCollection>;
  category: PotluckCollection;
}

interface Props {
  sideDish?: CollectionEntry<"side-dishes">;
  dessert?: CollectionEntry<"desserts">;
  platesCutlery?: CollectionEntry<"plates-cutlery">;
  drink?: CollectionEntry<"drinks">;
}

const { sideDish, dessert, platesCutlery, drink } = Astro.props;

const plateItems: PlateItem[] = [
  sideDish && { item: sideDish, category: "side-dishes" as const },
  dessert && { item: dessert, category: "desserts" as const },
  platesCutlery && { item: platesCutlery, category: "plates-cutlery" as const },
  drink && { item: drink, category: "drinks" as const },
].filter(Boolean) as PlateItem[];

const categoryDescriptions: Record<PotluckCollection, string> = {
  "side-dishes": "Something to know about",
  desserts: "Something sweet",
  "plates-cutlery": "Historical context",
  drinks: "Something to thirst for",
};
---

<div class="plate-display">
  {
    plateItems.map(({ item, category }) => (
      <div class="plate-display__item">
        <div class="plate-display__category-row">
          <CategoryBadge category={category} href={`/${category}/`} />
          <span class="plate-display__category-description">
            {categoryDescriptions[category]}
          </span>
        </div>
        <PotluckCard
          title={item.data.title}
          description={item.data.description}
          href={`/${category}/${item.slug}/`}
          tags={item.data.tags}
          icon={item.data.icon}
          category={category}
        />
      </div>
    ))
  }
</div>

<style>
  .plate-display {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-xl);
  }

  .plate-display__item {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .plate-display__category-row {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }

  .plate-display__category-description {
    font-size: var(--font-size-sm);
    color: var(--text-color-lighter);
    font-style: italic;
  }

  @media (min-width: 768px) {
    .plate-display {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
