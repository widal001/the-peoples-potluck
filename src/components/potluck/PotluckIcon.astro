---
interface Props {
  svg?: string;
  primaryColor?: string;
  secondaryColor?: string;
  size?: "sm" | "md" | "lg";
}

const {
  svg = "default",
  primaryColor = "var(--secondary)",
  secondaryColor = "var(--accent)",
  size = "md",
} = Astro.props;

const sizeClasses = {
  sm: "potluck-icon--sm",
  md: "potluck-icon--md",
  lg: "potluck-icon--lg",
};
---

<div
  class={`potluck-icon ${sizeClasses[size]}`}
  style={`--icon-primary: ${primaryColor}; --icon-secondary: ${secondaryColor};`}
  aria-hidden="true"
  title={svg}
>
</div>

<style>
  .potluck-icon {
    display: block;
    border-radius: var(--radius-lg);
    background: linear-gradient(
      135deg,
      var(--icon-primary) 0%,
      var(--icon-secondary) 100%
    );
    flex-shrink: 0;
  }

  .potluck-icon--sm {
    width: 2.5rem;
    height: 2.5rem;
  }

  .potluck-icon--md {
    width: 3rem;
    height: 3rem;
  }

  .potluck-icon--lg {
    width: 4rem;
    height: 4rem;
  }
</style>
