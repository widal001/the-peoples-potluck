---
import PotluckCard from "./PotluckCard.svelte";
import type { CollectionEntry } from "astro:content";
import type { PotluckCategory } from "@/config/collections";
import type { PotluckItem } from "@/lib/filters/types";

type PotluckCollection = PotluckCategory;

interface Props {
  title: string;
  description?: string;
  items: CollectionEntry<PotluckCollection>[];
  category: PotluckCollection;
  viewAllHref: string;
  maxItems?: number;
}

const {
  title,
  description,
  items,
  category,
  viewAllHref,
  maxItems = 5,
} = Astro.props;

const displayItems = items.slice(0, maxItems);

// Transform collection entries to PotluckItem format
const toPotluckItem = (entry: CollectionEntry<PotluckCollection>): PotluckItem => ({
  slug: entry.slug,
  title: entry.data.title,
  description: entry.data.description,
  tags: entry.data.tags,
  icon: entry.data.icon,
  flavor: entry.data.flavor,
});
---

<section class="scroll-section">
  <div class="scroll-section__inner">
    <div class="scroll-section__header">
      <h2 class="scroll-section__title">{title}</h2>
      <a href={viewAllHref} class="scroll-section__view-all">
        View all
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>

    {description && <p class="scroll-section__description">{description}</p>}
  </div>

  <div class="scroll-container">
    <ul class="scroll-list">
      {
        displayItems.map((item) => (
          <li class="scroll-item">
            <PotluckCard
              item={toPotluckItem(item)}
              category={category}
              compact={true}
            />
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .scroll-section {
    padding-block: var(--spacing-lg);
  }

  .scroll-section__inner {
    padding-inline: var(--section-padding-x);
    max-width: calc(var(--container-max-width) + var(--section-padding-x) * 2);
    margin-inline: auto;
  }

  .scroll-section__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }

  .scroll-section__title {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--text-color-default);
    margin: 0;
  }

  .scroll-section__view-all {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-medium);
    color: var(--accent);
    text-decoration: none;
    transition: color var(--transition-normal);
    white-space: nowrap;
  }

  .scroll-section__view-all:hover {
    color: var(--accent-dark);
  }

  .scroll-section__view-all svg {
    transition: transform var(--transition-normal);
  }

  .scroll-section__view-all:hover svg {
    transform: translateX(4px);
  }

  .scroll-section__description {
    font-size: var(--font-size-md);
    color: var(--text-color-lighter);
    margin: 0;
  }

  .scroll-container {
    overflow-x: auto;
    overflow-y: visible;
    /* Padding for hover lift at top and scrollbar at bottom */
    padding-top: var(--spacing-lg);
    padding-bottom: var(--spacing-lg);
    /* Align scrollbar with content */
    max-width: calc(var(--container-max-width) + var(--section-padding-x) * 2);
    margin-inline: auto;
    padding-inline: var(--section-padding-x);
    /* Always reserve space for scrollbar, but make it transparent until hover */
    scrollbar-width: thin; /* Firefox */
    scrollbar-color: transparent transparent;
  }

  .scroll-container::-webkit-scrollbar {
    height: 8px;
  }

  .scroll-container::-webkit-scrollbar-track {
    background: transparent;
  }

  .scroll-container::-webkit-scrollbar-thumb {
    background-color: transparent;
    border-radius: 4px;
    transition: background-color 0.2s ease;
  }

  .scroll-container:hover {
    scrollbar-color: var(--secondary-light) transparent; /* Firefox */
  }

  .scroll-container:hover::-webkit-scrollbar-thumb {
    background-color: var(--secondary-light);
  }

  .scroll-list {
    display: flex;
    gap: var(--spacing-lg);
    list-style: none;
    margin: 0;
    padding: 0;
    /* Extend past container to edge of screen */
    width: max-content;
    padding-right: max(
      var(--section-padding-x),
      calc((100vw - var(--container-max-width)) / 2)
    );
  }

  .scroll-item {
    flex: 0 0 auto;
    width: 340px;
  }

  /* Responsive adjustments */
  @media (max-width: 640px) {
    .scroll-item {
      width: 300px;
    }

    .scroll-section__header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-sm);
    }

    .scroll-list {
      padding-right: var(--section-padding-x);
    }
  }
</style>
