---
import PotluckIcon from "./PotluckIcon.astro";
import TagPill from "./TagPill.astro";
import type { CollectionEntry } from "astro:content";

type PotluckCollection =
  | "side-dishes"
  | "desserts"
  | "plates-cutlery"
  | "drinks";

interface Props {
  title: string;
  description?: string;
  items: CollectionEntry<PotluckCollection>[];
  category: PotluckCollection;
  viewAllHref: string;
  maxItems?: number;
}

const {
  title,
  description,
  items,
  category,
  viewAllHref,
  maxItems = 5,
} = Astro.props;

const displayItems = items.slice(0, maxItems);
const basePath = `/${category}`;

// Truncate description for card view
const truncate = (str: string, maxLength = 150) =>
  str.length > maxLength ? str.slice(0, maxLength) + "..." : str;
---

<section class="scroll-section">
  <div class="scroll-section__inner">
    <div class="scroll-section__header">
      <h2 class="scroll-section__title">{title}</h2>
      <a href={viewAllHref} class="scroll-section__view-all">
        View all
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>

    {description && <p class="scroll-section__description">{description}</p>}
  </div>

  <div class="scroll-container">
    <ul class="scroll-list">
      {
        displayItems.map((item) => (
          <li class="scroll-item">
            <a
              href={`${basePath}/${item.slug}/`}
              class="scroll-card-link"
              aria-label={`Read more about ${item.data.title}`}
            >
              <article class="scroll-card">
                <div class="scroll-card__header">
                  {item.data.icon && (
                    <PotluckIcon
                      svg={item.data.icon.svg}
                      primaryColor={item.data.icon.primaryColor}
                      secondaryColor={item.data.icon.secondaryColor}
                      size="md"
                    />
                  )}
                  <h3 class="scroll-card__title">{item.data.title}</h3>
                </div>
                <p class="scroll-card__description">
                  {truncate(item.data.description)}
                </p>
                {item.data.tags && item.data.tags.length > 0 && (
                  <div class="scroll-card__tags">
                    {item.data.tags.slice(0, 4).map((tag) => (
                      <TagPill tag={tag} size="sm" />
                    ))}
                  </div>
                )}
              </article>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .scroll-section {
    padding-block: var(--spacing-xl);
  }

  .scroll-section__inner {
    padding-inline: var(--section-padding-x);
    max-width: calc(var(--container-max-width) + var(--section-padding-x) * 2);
    margin-inline: auto;
  }

  .scroll-section__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }

  .scroll-section__title {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--text-color-default);
    margin: 0;
  }

  .scroll-section__view-all {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-medium);
    color: var(--accent);
    text-decoration: none;
    transition: color var(--transition-normal);
    white-space: nowrap;
  }

  .scroll-section__view-all:hover {
    color: var(--accent-dark);
  }

  .scroll-section__view-all svg {
    transition: transform var(--transition-normal);
  }

  .scroll-section__view-all:hover svg {
    transform: translateX(4px);
  }

  .scroll-section__description {
    font-size: var(--font-size-md);
    color: var(--text-color-lighter);
    margin: 0;
  }

  .scroll-container {
    overflow-x: auto;
    overflow-y: visible;
    /* Padding for hover lift at top and scrollbar at bottom */
    padding-top: var(--spacing-lg);
    padding-bottom: var(--spacing-sm);
    /* Align scrollbar with content */
    max-width: calc(var(--container-max-width) + var(--section-padding-x) * 2);
    margin-inline: auto;
    padding-inline: var(--section-padding-x);
    /* Always reserve space for scrollbar, but make it transparent until hover */
    scrollbar-width: thin; /* Firefox */
    scrollbar-color: transparent transparent;
  }

  .scroll-container::-webkit-scrollbar {
    height: 8px;
  }

  .scroll-container::-webkit-scrollbar-track {
    background: transparent;
  }

  .scroll-container::-webkit-scrollbar-thumb {
    background-color: transparent;
    border-radius: 4px;
    transition: background-color 0.2s ease;
  }

  .scroll-container:hover {
    scrollbar-color: var(--secondary-light) transparent; /* Firefox */
  }

  .scroll-container:hover::-webkit-scrollbar-thumb {
    background-color: var(--secondary-light);
  }

  .scroll-list {
    display: flex;
    gap: var(--spacing-lg);
    list-style: none;
    margin: 0;
    padding: 0;
    /* Extend past container to edge of screen */
    width: max-content;
    padding-right: max(
      var(--section-padding-x),
      calc((100vw - var(--container-max-width)) / 2)
    );
  }

  .scroll-item {
    flex: 0 0 auto;
    width: 340px;
  }

  .scroll-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .scroll-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 220px;
    padding: var(--spacing-lg);
    background-color: var(--background-default);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
    transition:
      transform var(--transition-normal) ease,
      border-color var(--transition-normal) ease,
      box-shadow var(--transition-normal) ease;
  }

  .scroll-card-link:hover .scroll-card,
  .scroll-card-link:focus .scroll-card {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
  }

  .scroll-card-link:focus {
    outline: none;
  }

  .scroll-card-link:focus .scroll-card {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .scroll-card__header {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }

  .scroll-card__title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--text-color-default);
    margin: 0;
    line-height: 1.3;
  }

  .scroll-card__description {
    font-size: var(--font-size-md);
    color: var(--text-color-default);
    opacity: 0.8;
    margin: 0 0 var(--spacing-md) 0;
    flex-grow: 1;
    line-height: 1.5;
  }

  .scroll-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-top: auto;
  }

  /* Responsive adjustments */
  @media (max-width: 640px) {
    .scroll-item {
      width: 300px;
    }

    .scroll-section__header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-sm);
    }

    .scroll-list {
      padding-right: var(--section-padding-x);
    }
  }
</style>
