---
import Layout from "@/layouts/Layout.astro";

interface Props {
  title: string;
  description: string;
  lastUpdated?: string;
}

const { title, description, lastUpdated } = Astro.props;
---

<Layout title={title} description={description}>
  <section class="section-padding">
    <div class="container-content">
      <h1 class="text-heading-1" style="margin-bottom: var(--spacing-md);">
        {title}
      </h1>
      <div class="title-accent"></div>
      {
        lastUpdated && (
          <p class="text-body-small" style="margin-bottom: var(--spacing-2xl);">
            Last updated: {lastUpdated}
          </p>
        )
      }
      <div class="prose prose-lg">
        <slot />
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  /* Prose styles */
  .prose {
    color: var(--text-color-default);
    font-family: var(--font-family-base);
    line-height: 1.75;
    max-width: 65ch;
    word-spacing: 0.05em;
  }

  .prose > p {
    color: var(--text-color-default);
    font-size: var(--font-size-md);
    margin-bottom: var(--spacing-xl);
    opacity: 0.9;
  }

  .prose > p:first-of-type {
    font-size: var(--font-size-xl);
    opacity: 1;
  }

  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4 {
    color: var(--text-color-default);
    font-weight: var(--font-weight-semibold);
    line-height: 1.2;
    margin-bottom: var(--spacing-md);
    margin-top: 2.5rem;
  }

  .prose h1 {
    font-size: clamp(var(--font-size-3xl), 4vw, var(--font-size-4xl));
  }

  .prose h2 {
    font-size: var(--font-size-2xl);
  }

  .prose h3 {
    font-size: var(--font-size-xl);
  }

  .prose h4 {
    font-size: var(--font-size-lg);
  }

  .prose ul,
  .prose ol {
    color: var(--text-color-default);
    font-size: var(--font-size-md);
    list-style-position: outside;
    margin-bottom: var(--spacing-xl);
    padding-left: var(--spacing-xl);
  }

  .prose ul {
    list-style-type: disc;
  }

  .prose ul ul {
    list-style-type: circle;
  }

  .prose ol {
    list-style-type: decimal;
  }

  .prose li {
    color: var(--text-color-default);
    margin-bottom: 0.5rem;
  }

  .prose a {
    color: var(--text-color-default);
    text-decoration: underline;
    text-underline-offset: 0.25rem;
    transition: color var(--transition-normal);
  }

  .prose a:hover {
    opacity: 0.8;
  }

  .prose code {
    background-color: var(--secondary-lightest);
    border-radius: var(--radius-sm);
    color: var(--text-color-default);
    font-family: ui-monospace, monospace;
    font-size: var(--font-size-sm);
    padding: 0.125rem 0.375rem;
  }

  .prose pre {
    background-color: var(--secondary-lightest);
    border-radius: var(--radius-lg);
    color: var(--text-color-default);
    font-size: var(--font-size-sm);
    margin-bottom: var(--spacing-xl);
    overflow-x: auto;
    padding: var(--spacing-md);
  }

  .prose blockquote {
    border-left: 4px solid var(--border-default);
    color: var(--text-color-default);
    font-style: italic;
    margin-bottom: var(--spacing-xl);
    margin-top: var(--spacing-xl);
    opacity: 0.8;
    padding-left: var(--spacing-md);
  }

  .prose strong {
    color: var(--text-color-default);
    font-weight: var(--font-weight-semibold);
  }

  .prose .button-primary {
    color: var(--white);
    text-decoration: none;
  }

  .prose .button-primary:hover {
    color: var(--white);
    opacity: 0.9;
  }
</style>
