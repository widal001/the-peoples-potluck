---
import "@/styles/global.css";
import Navigation from "@/components/layout/Navigation.astro";
import Footer from "@/components/layout/Footer.astro";
import {
  navItems as defaultNavItems,
  footerConfig as defaultFooterConfig,
  siteConfig,
  type NavItem,
  type NavDropdown,
  type FooterProps,
} from "@/config/site.ts";

interface Props {
  title: string;
  description: string;
  logoHref?: string;
  navItems?: (NavItem | NavDropdown)[];
  footer?: Partial<FooterProps>;
}

const {
  title,
  description,
  logoHref = siteConfig.logoHref,
  navItems = defaultNavItems,
  footer,
} = Astro.props;

// Merge footer config with defaults
const footerProps = { ...defaultFooterConfig, ...footer };
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <!-- Google Fonts - Preconnect for faster loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Load Google Fonts asynchronously (non-blocking) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=optional"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <!-- Fallback to blocking load if JavaScript is disabled -->
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=optional"
        rel="stylesheet"
      />
    </noscript>
    <title>{title} | {siteConfig.companyName}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <a href="#main-content" class="skip-link"> Skip to main content </a>
    <Navigation logoHref={logoHref} items={navItems} />
    <main id="main-content">
      <slot />
    </main>
    <Footer
      companyName={footerProps.companyName}
      links={footerProps.links}
      showContactSection={footerProps.showContactSection}
      contactTitle={footerProps.contactTitle}
      contactTagline={footerProps.contactTagline}
      contactButtonHref={footerProps.contactButtonHref}
    />
  </body>
</html>
