---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import ActiveFilters from "@/components/filters/ActiveFilters.svelte";
import FilterPanel from "@/components/filters/FilterPanel.svelte";
import FilterableGrid from "@/components/filters/FilterableGrid.svelte";
import { prepareCollectionItems } from "@/lib/filters";

const items = prepareCollectionItems(await getCollection("plates-cutlery"));
---

<Layout
  title="Plates & Cutlery"
  description="Local historical context of what Baltimore is already carrying related to ICE, policing, and immigration rights."
>
  <section class="section-padding">
    <div class="container-content">
      <header class="page-header">
        <h1 class="text-heading-1">Plates & Cutlery</h1>
        <div class="title-accent"></div>
        <p class="text-body-large page-description">
          Local historical context of what Baltimore is already carrying related
          to ICE, policing, and immigration rights. It might be a history of
          harm, institutions, solidarity, and/or resistance.
        </p>
      </header>

      <div class="filter-controls">
        <ActiveFilters client:load />
        <FilterPanel client:load />
      </div>

      <FilterableGrid
        {items}
        category="plates-cutlery"
        emptyMessage="No historical context matches your filters. Try adjusting the flavor profile or reset filters."
        client:load
      />
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: var(--spacing-xl);
  }

  .page-description {
    max-width: 65ch;
  }

  .filter-controls {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }
</style>
