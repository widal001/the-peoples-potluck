---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PotluckGrid from "@/components/potluck/PotluckGrid.astro";

const platesCutlery = await getCollection("plates-cutlery");

// Sort by addedDate if available, newest first
const sortedItems = platesCutlery.sort((a, b) => {
  const dateA = a.data.addedDate ? new Date(a.data.addedDate).getTime() : 0;
  const dateB = b.data.addedDate ? new Date(b.data.addedDate).getTime() : 0;
  return dateB - dateA;
});
---

<Layout
  title="Plates & Cutlery"
  description="Local historical context of what Baltimore is already carrying related to ICE, policing, and immigration rights."
>
  <section class="section-padding">
    <div class="container-content">
      <header class="page-header">
        <h1 class="text-heading-1">Plates & Cutlery</h1>
        <div class="title-accent"></div>
        <p class="text-body-large page-description">
          Local historical context of what Baltimore is already carrying related
          to ICE, policing, and immigration rights. It might be a history of
          harm, institutions, solidarity, and/or resistance.
        </p>
      </header>

      <PotluckGrid
        items={sortedItems}
        category="plates-cutlery"
        emptyMessage="No historical context added yet. Check back soon!"
      />
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: var(--spacing-3xl);
  }

  .page-description {
    max-width: 65ch;
  }
</style>
