---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import ActiveFilters from "@/components/filters/ActiveFilters.svelte";
import FilterPanel from "@/components/filters/FilterPanel.svelte";
import FilterableGrid from "@/components/filters/FilterableGrid.svelte";
import { prepareCollectionItems } from "@/lib/filters";

const items = prepareCollectionItems(await getCollection("side-dishes"));
---

<Layout
  title="Side Dishes"
  description="Existing groups, efforts, and projects in Baltimore related to solidarity with immigrants, disrupting ICE/policing, and more."
>
  <section class="section-padding">
    <div class="container-content">
      <header class="page-header">
        <h1 class="text-heading-1">Side Dishes</h1>
        <div class="title-accent"></div>
        <p class="text-body-large page-description">
          Existing groups, efforts, and projects in Baltimore that feel worth
          knowing about related to solidarity with immigrants, disrupting
          ICE/policing, and community care.
        </p>
      </header>

      <div class="filter-controls">
        <ActiveFilters client:load />
        <FilterPanel client:load />
      </div>

      <FilterableGrid
        {items}
        category="side-dishes"
        emptyMessage="No side dishes match your filters. Try adjusting the flavor profile or reset filters."
        client:load
      />
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: var(--spacing-xl);
  }

  .page-description {
    max-width: 65ch;
  }

  .filter-controls {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }
</style>
