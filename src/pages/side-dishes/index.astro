---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PotluckGrid from "@/components/potluck/PotluckGrid.astro";

const sideDishes = await getCollection("side-dishes");

// Sort by addedDate if available, newest first
const sortedItems = sideDishes.sort((a, b) => {
  const dateA = a.data.addedDate ? new Date(a.data.addedDate).getTime() : 0;
  const dateB = b.data.addedDate ? new Date(b.data.addedDate).getTime() : 0;
  return dateB - dateA;
});
---

<Layout
  title="Side Dishes"
  description="Existing groups, efforts, and projects in Baltimore related to solidarity with immigrants, disrupting ICE/policing, and more."
>
  <section class="section-padding">
    <div class="container-content">
      <header class="page-header">
        <h1 class="text-heading-1">Side Dishes</h1>
        <div class="title-accent"></div>
        <p class="text-body-large page-description">
          Existing groups, efforts, and projects in Baltimore that feel worth
          knowing about related to solidarity with immigrants, disrupting
          ICE/policing, and community care.
        </p>
      </header>

      <PotluckGrid
        items={sortedItems}
        category="side-dishes"
        emptyMessage="No side dishes added yet. Check back soon for community resources!"
      />
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: var(--spacing-3xl);
  }

  .page-description {
    max-width: 65ch;
  }
</style>
