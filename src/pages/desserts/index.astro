---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import ActiveFilters from "@/components/filters/ActiveFilters.svelte";
import FilterPanel from "@/components/filters/FilterPanel.svelte";
import FilterableGrid from "@/components/filters/FilterableGrid.svelte";
import { prepareCollectionItems } from "@/lib/filters";

const items = prepareCollectionItems(await getCollection("desserts"));
---

<Layout
  title="Desserts"
  description="Sweet things giving hope - efforts, projects, mutual aid initiatives, and experiments keeping communities safe against ICE/policing."
>
  <section class="section-padding">
    <div class="container-content">
      <header class="page-header">
        <h1 class="text-heading-1">Desserts</h1>
        <div class="title-accent"></div>
        <p class="text-body-large page-description">
          Sweet things giving you hope - efforts, projects, mutual aid
          initiatives, and other experiments that you've heard of, whether here
          or elsewhere, related to the possibility of keeping community safe
          against ICE/policing.
        </p>
      </header>

      <div class="filter-controls">
        <ActiveFilters client:load />
        <FilterPanel client:load />
      </div>

      <FilterableGrid
        {items}
        category="desserts"
        emptyMessage="No desserts match your filters. Try adjusting the flavor profile or reset filters."
        client:load
      />
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: var(--spacing-xl);
  }

  .page-description {
    max-width: 65ch;
  }

  .filter-controls {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }
</style>
