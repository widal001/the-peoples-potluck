---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PotluckGrid from "@/components/potluck/PotluckGrid.astro";

const desserts = await getCollection("desserts");

// Sort by addedDate if available, newest first
const sortedItems = desserts.sort((a, b) => {
  const dateA = a.data.addedDate ? new Date(a.data.addedDate).getTime() : 0;
  const dateB = b.data.addedDate ? new Date(b.data.addedDate).getTime() : 0;
  return dateB - dateA;
});
---

<Layout
  title="Desserts"
  description="Sweet things giving hope - efforts, projects, mutual aid initiatives, and experiments keeping communities safe against ICE/policing."
>
  <section class="section-padding">
    <div class="container-content">
      <header class="page-header">
        <h1 class="text-heading-1">Desserts</h1>
        <div class="title-accent"></div>
        <p class="text-body-large page-description">
          Sweet things giving you hope - efforts, projects, mutual aid
          initiatives, and other experiments that you've heard of, whether here
          or elsewhere, related to the possibility of keeping community safe
          against ICE/policing.
        </p>
      </header>

      <PotluckGrid
        items={sortedItems}
        category="desserts"
        emptyMessage="No desserts added yet. Check back soon for hopeful initiatives!"
      />
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: var(--spacing-3xl);
  }

  .page-description {
    max-width: 65ch;
  }
</style>
