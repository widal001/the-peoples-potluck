---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import ActiveFilters from "@/components/filters/ActiveFilters.svelte";
import FilterPanel from "@/components/filters/FilterPanel.svelte";
import FilterableGrid from "@/components/filters/FilterableGrid.svelte";
import { prepareCollectionItems } from "@/lib/filters";

const items = prepareCollectionItems(await getCollection("desserts"));
---

<Layout
  title="Desserts"
  description="See what's possible. Successes, case studies, and stories that show what community power can do."
>
  <section class="section-padding">
    <div class="container-content">
      <header class="page-header">
        <h1 class="text-heading-1">Desserts</h1>
        <p class="page-tagline">Worth saving room for</p>
        <div class="title-accent"></div>
        <p class="text-body-large page-description">
          See what's possible. Successes, case studies, and stories that show
          what community power can do.
        </p>
      </header>

      <div class="filter-controls">
        <ActiveFilters client:load />
        <FilterPanel client:load />
      </div>

      <FilterableGrid
        {items}
        category="desserts"
        emptyMessage="No desserts match your filters. Try adjusting the flavor profile or reset filters."
        client:load
      />
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: var(--spacing-xl);
  }

  .page-tagline {
    font-size: var(--font-size-lg);
    font-style: italic;
    color: var(--text-color-lighter);
    margin-bottom: var(--spacing-sm);
  }

  .page-description {
    max-width: 65ch;
  }

  .filter-controls {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }
</style>
