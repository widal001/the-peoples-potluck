---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import CategoryBadge from "@/components/potluck/CategoryBadge.astro";
import TagPill from "@/components/potluck/TagPill.astro";
import PotluckIcon from "@/components/potluck/PotluckIcon.astro";
import FlavorProfile from "@/components/potluck/FlavorProfile.astro";
import LinkButton from "@/components/ui/LinkButton.astro";

export async function getStaticPaths() {
  const items = await getCollection("desserts");
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

interface Props {
  item: CollectionEntry<"desserts">;
}

const { item } = Astro.props;
const { Content } = await item.render();
---

<Layout title={item.data.title} description={item.data.description}>
  <article class="section-padding">
    <div class="container-content">
      <nav class="breadcrumb">
        <a href="/desserts/" class="breadcrumb__link">Desserts</a>
        <span class="breadcrumb__separator" aria-hidden="true">/</span>
        <span class="breadcrumb__current">{item.data.title}</span>
      </nav>

      <header class="detail-header">
        <CategoryBadge category="desserts" href="/desserts/" />

        <div class="detail-header__main">
          {
            item.data.icon && (
              <PotluckIcon
                svg={item.data.icon.svg}
                primaryColor={item.data.icon.primaryColor}
                secondaryColor={item.data.icon.secondaryColor}
                size="lg"
              />
            )
          }
          <h1 class="text-heading-1">{item.data.title}</h1>
        </div>

        <p class="text-body-large detail-description">
          {item.data.description}
        </p>

        {
          item.data.tags && item.data.tags.length > 0 && (
            <div class="detail-tags">
              {item.data.tags.map((tag) => (
                <TagPill tag={tag} />
              ))}
            </div>
          )
        }

        {item.data.flavor && (
          <div class="detail-flavor">
            <FlavorProfile flavor={item.data.flavor} />
          </div>
        )}
      </header>

      <div class="detail-content prose">
        <Content />
      </div>

      <footer class="detail-footer">
        {
          item.data.sourceUrl && (
            <LinkButton href={item.data.sourceUrl} text="Learn more" />
          )
        }
        {
          item.data.source && !item.data.sourceUrl && (
            <p class="detail-source">Source: {item.data.source}</p>
          )
        }
      </footer>

      <nav class="detail-nav">
        <a href="/desserts/" class="detail-nav__back">
          &larr; Back to Desserts
        </a>
      </nav>
    </div>
  </article>
</Layout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xl);
    font-size: var(--font-size-sm);
  }

  .breadcrumb__link {
    color: var(--accent);
    text-decoration: none;
  }

  .breadcrumb__link:hover {
    text-decoration: underline;
  }

  .breadcrumb__separator {
    color: var(--text-color-lighter);
  }

  .breadcrumb__current {
    color: var(--text-color-lighter);
  }

  .detail-header {
    margin-bottom: var(--spacing-3xl);
  }

  .detail-header__main {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-lg);
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
  }

  .detail-description {
    max-width: 65ch;
    margin-bottom: var(--spacing-lg);
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .detail-flavor {
    margin-top: var(--spacing-lg);
    padding: var(--spacing-md);
    background-color: var(--secondary-lightest);
    border-radius: var(--radius-md);
  }

  .detail-content {
    margin-bottom: var(--spacing-3xl);
  }

  .detail-content :global(h2) {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-md);
  }

  .detail-content :global(p) {
    margin-bottom: var(--spacing-md);
    line-height: 1.7;
  }

  .detail-content :global(ul),
  .detail-content :global(ol) {
    margin-bottom: var(--spacing-md);
    padding-left: var(--spacing-xl);
  }

  .detail-content :global(li) {
    margin-bottom: var(--spacing-sm);
    line-height: 1.6;
  }

  .detail-content :global(strong) {
    font-weight: var(--font-weight-semibold);
  }

  .detail-footer {
    margin-bottom: var(--spacing-2xl);
  }

  .detail-source {
    font-size: var(--font-size-sm);
    color: var(--text-color-lighter);
    font-style: italic;
  }

  .detail-nav {
    padding-top: var(--spacing-xl);
    border-top: 1px solid var(--border-default);
  }

  .detail-nav__back {
    color: var(--accent);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
  }

  .detail-nav__back:hover {
    text-decoration: underline;
  }
</style>
