---
/**
 * Dynamic collection detail page
 * Handles: /settings/[slug], /dishes/[slug], /desserts/[slug], /drinks/[slug], /bites/[slug]
 *
 * Static generation by default. To enable SSR for dynamic content:
 * export const prerender = false;
 */
import { getCollection, getEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import CategoryBadge from "@/components/potluck/CategoryBadge.astro";
import TagPill from "@/components/potluck/TagPill.astro";
import PotluckIcon from "@/components/potluck/PotluckIcon.astro";
import FlavorProfileCard from "@/components/potluck/FlavorProfileCard.astro";
import LinkButton from "@/components/ui/LinkButton.astro";
import SuggestedBites from "@/components/potluck/SuggestedBites.svelte";
import {
  COLLECTION_KEYS,
  COLLECTIONS,
  type PotluckCategory,
} from "@/config/collections";
import {
  getItemBySlug,
  getCollectionItems,
  toPotluckItem,
  toFlavorProfile,
} from "@/lib/data";

// Generate static paths for all items in all collections
export async function getStaticPaths() {
  const paths = await Promise.all(
    COLLECTION_KEYS.map(async (category) => {
      const items = await getCollection(category);
      return items.map((item) => ({
        params: { category, slug: item.slug },
      }));
    }),
  );
  return paths.flat();
}

const { category, slug } = Astro.params as { category: PotluckCategory; slug: string };
const config = COLLECTIONS[category];

// Fetch the item (D1 if available, content collection fallback)
const item = await getItemBySlug(Astro, category, slug);

// With getStaticPaths, the item should always exist
if (!item) {
  throw new Error(`Item not found: ${category}/${slug}`);
}

// For rendering MDX content, we need the content collection entry
const contentEntry = await getEntry(category, slug);

// Get bites for suggested section (only for non-bites collections)
const showSuggestedBites = category !== "bites";
const bitesItems = showSuggestedBites
  ? await getCollectionItems(Astro, "bites")
  : [];
const allBites = bitesItems.map(toPotluckItem);

// Render MDX content if available from content collection
const Content = contentEntry ? (await contentEntry.render()).Content : null;
---

<Layout title={item.title} description={item.description}>
  <article class="section-padding">
    <div class="container-content">
      <nav class="breadcrumb">
        <a href={config.path} class="breadcrumb__link">{config.label}</a>
        <span class="breadcrumb__separator" aria-hidden="true">/</span>
        <span class="breadcrumb__current">{item.title}</span>
      </nav>

      <header class="detail-header">
        <CategoryBadge {category} href={config.path} />

        <div class="detail-header__main">
          {
            item.icon && (
              <PotluckIcon
                svg={item.icon.svg}
                primaryColor={item.icon.primaryColor}
                secondaryColor={item.icon.secondaryColor}
                size="lg"
              />
            )
          }
          <h1 class="text-heading-1">{item.title}</h1>
        </div>

        <p class="text-body-large detail-description">
          {item.description}
        </p>

        {
          item.tags && item.tags.length > 0 && (
            <div class="detail-tags">
              {item.tags.map((tag) => (
                <TagPill tag={tag} />
              ))}
            </div>
          )
        }

        {
          (item.flavor.heat || item.flavor.sweet || item.flavor.zest || item.flavor.heft) && (
            <div class="detail-flavor">
              <FlavorProfileCard flavor={toFlavorProfile(item.flavor)} />
            </div>
          )
        }
      </header>

      {
        Content && (
          <div class="detail-content prose">
            <Content />
          </div>
        )
      }

      <footer class="detail-footer">
        {
          item.sourceUrl && (
            <LinkButton href={item.sourceUrl} text="Learn more" />
          )
        }
        {
          item.source && !item.sourceUrl && (
            <p class="detail-source">Source: {item.source}</p>
          )
        }
      </footer>

      <nav class="detail-nav">
        <a href={config.path} class="detail-nav__back">
          &larr; Back to {config.label}
        </a>
      </nav>

      {
        showSuggestedBites && (
          <SuggestedBites bites={allBites} maxItems={3} client:load />
        )
      }
    </div>
  </article>
</Layout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xl);
    font-size: var(--font-size-sm);
  }

  .breadcrumb__link {
    color: var(--accent);
    text-decoration: none;
  }

  .breadcrumb__link:hover {
    text-decoration: underline;
  }

  .breadcrumb__separator {
    color: var(--text-color-lighter);
  }

  .breadcrumb__current {
    color: var(--text-color-lighter);
  }

  .detail-header {
    margin-bottom: var(--spacing-3xl);
  }

  .detail-header__main {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-lg);
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
  }

  .detail-description {
    max-width: 65ch;
    margin-bottom: var(--spacing-lg);
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
  }

  .detail-flavor {
    max-width: 800px;
    margin-inline: auto;
  }

  .detail-content {
    margin-bottom: var(--spacing-3xl);
  }

  .detail-content :global(h2) {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-md);
  }

  .detail-content :global(p) {
    margin-bottom: var(--spacing-md);
    line-height: 1.7;
  }

  .detail-content :global(ul),
  .detail-content :global(ol) {
    margin-bottom: var(--spacing-md);
    padding-left: var(--spacing-xl);
  }

  .detail-content :global(li) {
    margin-bottom: var(--spacing-sm);
    line-height: 1.6;
  }

  .detail-content :global(strong) {
    font-weight: var(--font-weight-semibold);
  }

  .detail-footer {
    margin-bottom: var(--spacing-2xl);
  }

  .detail-source {
    font-size: var(--font-size-sm);
    color: var(--text-color-lighter);
    font-style: italic;
  }

  .detail-nav {
    margin-top: var(--spacing-2xl);
  }

  .detail-nav__back {
    color: var(--accent);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
  }

  .detail-nav__back:hover {
    text-decoration: underline;
  }
</style>
