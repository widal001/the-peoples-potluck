---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import ActiveFilters from "@/components/filters/ActiveFilters.svelte";
import FilterPanel from "@/components/filters/FilterPanel.svelte";
import FilterableGrid from "@/components/filters/FilterableGrid.svelte";
import SuggestedBites from "@/components/potluck/SuggestedBites.svelte";
import { prepareCollectionItems, collectionEntryToItem } from "@/lib/filters";
import { COLLECTIONS } from "@/config/collections";

const config = COLLECTIONS.drinks;
const items = prepareCollectionItems(await getCollection("drinks"));
const bites = (await getCollection("bites")).map(collectionEntryToItem);
---

<Layout title={config.label} description={config.description}>
  <section class="section-padding">
    <div class="container-content">
      <header class="page-header">
        <h1 class="text-heading-1">{config.label}</h1>
        <p class="page-tagline">{config.tagline}</p>
        <div class="title-accent"></div>
        <p class="text-body-large page-description">
          {config.description}
        </p>
      </header>

      <div class="filter-controls">
        <ActiveFilters client:load />
        <FilterPanel client:load />
      </div>

      <FilterableGrid
        {items}
        category="drinks"
        emptyMessage="No drinks match your filters. Try adjusting the flavor profile or reset filters."
        client:load
      />

      <SuggestedBites {bites} client:load />
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: var(--spacing-xl);
  }

  .page-tagline {
    font-size: var(--font-size-lg);
    font-style: italic;
    color: var(--text-color-lighter);
    margin-bottom: var(--spacing-sm);
  }

  .page-description {
    max-width: 65ch;
  }

  .filter-controls {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }
</style>
