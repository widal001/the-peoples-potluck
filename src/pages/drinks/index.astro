---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import ActiveFilters from "@/components/filters/ActiveFilters.svelte";
import FilterPanel from "@/components/filters/FilterPanel.svelte";
import FilterableGrid from "@/components/filters/FilterableGrid.svelte";
import { prepareCollectionItems } from "@/lib/filters";

const items = prepareCollectionItems(await getCollection("drinks"));
---

<Layout
  title="Drinks"
  description="What Baltimore is thirsty for related to organizing, mutual aid, and solidarity around immigration."
>
  <section class="section-padding">
    <div class="container-content">
      <header class="page-header">
        <h1 class="text-heading-1">Drinks</h1>
        <div class="title-accent"></div>
        <p class="text-body-large page-description">
          What Baltimore is thirsty for related to organizing, mutual aid, and
          solidarity around immigration. Things you've experienced in other
          cities, or things you haven't found here yet that might make a
          difference locally.
        </p>
      </header>

      <div class="filter-controls">
        <ActiveFilters client:load />
        <FilterPanel client:load />
      </div>

      <FilterableGrid
        {items}
        category="drinks"
        emptyMessage="No drinks match your filters. Try adjusting the flavor profile or reset filters."
        client:load
      />
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: var(--spacing-xl);
  }

  .page-description {
    max-width: 65ch;
  }

  .filter-controls {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }
</style>
