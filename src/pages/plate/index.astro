---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PlateDisplay from "@/components/potluck/PlateDisplay.astro";
import RangeSlider from "@/components/ui/RangeSlider.astro";
import { FLAVOR_AXES } from "@/stores/filters";

// Fetch all collections
const sideDishes = await getCollection("side-dishes");
const desserts = await getCollection("desserts");
const platesCutlery = await getCollection("plates-cutlery");
const drinks = await getCollection("drinks");

// Helper to get random item from array
const getRandomItem = <T,>(arr: T[]): T | undefined => {
  if (arr.length === 0) return undefined;
  return arr[Math.floor(Math.random() * arr.length)];
};

// Get random items for initial server-side render
const randomSideDish = getRandomItem(sideDishes);
const randomDessert = getRandomItem(desserts);
const randomPlatesCutlery = getRandomItem(platesCutlery);
const randomDrink = getRandomItem(drinks);

// Prepare data for client-side randomization (now includes flavor data)
const allItems = {
  sideDishes: sideDishes.map((item) => ({
    slug: item.slug,
    title: item.data.title,
    description: item.data.description,
    tags: item.data.tags || [],
    icon: item.data.icon,
    flavor: item.data.flavor || {},
  })),
  desserts: desserts.map((item) => ({
    slug: item.slug,
    title: item.data.title,
    description: item.data.description,
    tags: item.data.tags || [],
    icon: item.data.icon,
    flavor: item.data.flavor || {},
  })),
  platesCutlery: platesCutlery.map((item) => ({
    slug: item.slug,
    title: item.data.title,
    description: item.data.description,
    tags: item.data.tags || [],
    icon: item.data.icon,
    flavor: item.data.flavor || {},
  })),
  drinks: drinks.map((item) => ({
    slug: item.slug,
    title: item.data.title,
    description: item.data.description,
    tags: item.data.tags || [],
    icon: item.data.icon,
    flavor: item.data.flavor || {},
  })),
};

// Flavor axes config for rendering sliders
const flavorAxes = Object.entries(FLAVOR_AXES) as [
  string,
  { label: string; minLabel: string; maxLabel: string },
][];
---

<Layout
  title="Your Plate"
  description="A random selection of resources from the Baltimore ICE Potluck - one side dish, one dessert, some plates & cutlery, and a drink."
>
  <section class="plate-page section-padding">
    <div class="container-content">
      <header class="plate-header">
        <h1 class="text-heading-1">Your Plate</h1>
        <div class="title-accent"></div>
        <p class="text-body-large plate-description">
          Here's a random selection from the potluck—one resource from each
          category. Use the flavor sliders to adjust what kind of resources
          you're looking for, then click the button to get a new combination.
        </p>
      </header>

      <!-- Filter Controls Container -->
      <div class="filter-controls">
        <!-- Active Filters Display -->
        <dl
          id="active-filters"
          class="active-filters"
          aria-live="polite"
          aria-label="Currently active flavor profile filters"
        >
        </dl>

        <!-- Flavor Filter Panel -->
        <details class="filter-panel" id="filter-panel">
          <summary class="filter-panel__toggle">
            <span class="filter-panel__toggle-text">Adjust flavor profile</span>
            <span class="filter-panel__toggle-indicator" aria-hidden="true"
            ></span>
          </summary>
          <div class="filter-panel__content">
            <div class="filter-panel__sliders">
              {
                flavorAxes.map(([axis, config]) => (
                  <RangeSlider
                    id={axis}
                    label={config.label}
                    minLabel={config.minLabel}
                    maxLabel={config.maxLabel}
                  />
                ))
              }
            </div>
            <div class="filter-panel__actions">
              <button
                id="reset-filters-btn"
                class="button-secondary button-sm"
                type="button"
              >
                Reset filters
              </button>
            </div>
          </div>
        </details>
      </div>

      <div class="plate-actions">
        <button id="new-plate-btn" class="button-primary">
          Make me a new plate
        </button>
        <p id="filter-status" class="filter-status" aria-live="polite"></p>
      </div>

      <div id="plate-container">
        <PlateDisplay
          sideDish={randomSideDish}
          dessert={randomDessert}
          platesCutlery={randomPlatesCutlery}
          drink={randomDrink}
        />
      </div>

      <div class="plate-footer">
        <p class="text-body">
          Want to explore more? Browse all resources in each category:
        </p>
        <nav class="category-links">
          <a href="/side-dishes/" class="category-link">Side Dishes</a>
          <a href="/desserts/" class="category-link">Desserts</a>
          <a href="/plates-cutlery/" class="category-link">Plates & Cutlery</a>
          <a href="/drinks/" class="category-link">Drinks</a>
        </nav>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ allItems }}>
  // ============================================
  // Filter State Management (inline nanostores-like)
  // ============================================

  const FLAVOR_AXES = ["heat", "sweet", "zest", "heft"];
  const DEFAULT_RANGE = [1, 5];

  // Current filter state
  const filters = {
    heat: [...DEFAULT_RANGE],
    sweet: [...DEFAULT_RANGE],
    zest: [...DEFAULT_RANGE],
    heft: [...DEFAULT_RANGE],
  };

  // Track which filters were explicitly set by user
  const userSetFilters = new Set();

  // ============================================
  // URL Sync
  // ============================================

  function loadFiltersFromURL() {
    const params = new URLSearchParams(window.location.search);

    for (const axis of FLAVOR_AXES) {
      const value = params.get(axis);
      if (value) {
        const [min, max] = value.split("-").map(Number);
        if (!isNaN(min) && !isNaN(max) && min >= 1 && max <= 5 && min <= max) {
          filters[axis] = [min, max];
          userSetFilters.add(axis);
        }
      }
    }
  }

  function syncFiltersToURL() {
    const params = new URLSearchParams(window.location.search);

    for (const axis of FLAVOR_AXES) {
      if (userSetFilters.has(axis)) {
        const [min, max] = filters[axis];
        if (min !== DEFAULT_RANGE[0] || max !== DEFAULT_RANGE[1]) {
          params.set(axis, `${min}-${max}`);
        } else {
          params.delete(axis);
        }
      } else {
        params.delete(axis);
      }
    }

    const newURL = params.toString()
      ? `${window.location.pathname}?${params.toString()}`
      : window.location.pathname;

    window.history.replaceState({}, "", newURL);
  }

  // ============================================
  // Filtering Logic
  // ============================================

  function filterItems(items) {
    return items.filter((item) => {
      const flavor = item.flavor || {};
      return FLAVOR_AXES.every((axis) => {
        const [min, max] = filters[axis];
        // If filter is at default, don't filter
        if (min === DEFAULT_RANGE[0] && max === DEFAULT_RANGE[1]) return true;
        // Default to middle value (3) if item doesn't have this axis
        const value = flavor[axis] ?? 3;
        return value >= min && value <= max;
      });
    });
  }

  // Calculate "distance" of an item from the current filters
  function getFilterDistance(item) {
    const flavor = item.flavor || {};
    let distance = 0;

    for (const axis of FLAVOR_AXES) {
      const [min, max] = filters[axis];
      if (min === DEFAULT_RANGE[0] && max === DEFAULT_RANGE[1]) continue;

      const value = flavor[axis] ?? 3;
      if (value < min) {
        distance += min - value;
      } else if (value > max) {
        distance += value - max;
      }
    }

    return distance;
  }

  // Get random item from filtered list, with closest-match fallback
  function getFilteredRandomItem(items) {
    if (!items || items.length === 0) return null;

    // Try exact filter match first
    const filtered = filterItems(items);
    if (filtered.length > 0) {
      return {
        item: filtered[Math.floor(Math.random() * filtered.length)],
        exact: true,
      };
    }

    // Find closest matches
    const withDistances = items.map((item) => ({
      item,
      distance: getFilterDistance(item),
    }));

    const minDistance = Math.min(...withDistances.map((d) => d.distance));
    const closest = withDistances.filter((d) => d.distance === minDistance);

    return {
      item: closest[Math.floor(Math.random() * closest.length)].item,
      exact: false,
    };
  }

  function hasActiveFilters() {
    return FLAVOR_AXES.some((axis) => {
      const [min, max] = filters[axis];
      return min !== DEFAULT_RANGE[0] || max !== DEFAULT_RANGE[1];
    });
  }

  function getActiveFiltersList() {
    const active = [];
    for (const axis of FLAVOR_AXES) {
      const [min, max] = filters[axis];
      if (min !== DEFAULT_RANGE[0] || max !== DEFAULT_RANGE[1]) {
        const label = axisLabels[axis];
        let rangeText;
        if (min === max) {
          rangeText = min;
        } else {
          rangeText = `${min}-${max}`;
        }
        active.push({ axis, name: label.name, range: rangeText });
      }
    }
    return active;
  }

  function updateActiveFiltersDisplay() {
    const active = getActiveFiltersList();

    if (active.length === 0) {
      activeFiltersDisplay.innerHTML = "";
      activeFiltersDisplay.classList.remove("active-filters--visible");
      return;
    }

    const pills = active
      .map((f) => {
        const label = axisLabels[f.axis];
        const [min, max] = filters[f.axis];
        const minLabel = label.min;
        const maxLabel = label.max;

        // Create descriptive range text for screen readers
        let rangeDesc;
        if (min === max) {
          if (min === 1) {
            rangeDesc = `set to ${minLabel}`;
          } else if (min === 5) {
            rangeDesc = `set to ${maxLabel}`;
          } else {
            rangeDesc = `set to ${min}`;
          }
        } else {
          const startDesc =
            min === 1 ? minLabel : min === 5 ? maxLabel : `${min}`;
          const endDesc =
            max === 5 ? maxLabel : max === 1 ? minLabel : `${max}`;
          rangeDesc = `from ${startDesc} to ${endDesc}`;
        }

        return `<div class="filter-pill" role="listitem">
        <dt class="filter-pill__name">${f.name}</dt>
        <dd class="filter-pill__value" aria-label="${f.name} filter ${rangeDesc}">${f.range}</dd>
      </div>`;
      })
      .join("");

    activeFiltersDisplay.innerHTML = `
      <span class="active-filters__label">Active filters:</span>
      <div role="list" class="active-filters__list">
        ${pills}
      </div>
    `;
    activeFiltersDisplay.classList.add("active-filters--visible");
  }

  // ============================================
  // DOM Elements
  // ============================================

  const newPlateBtn = document.getElementById("new-plate-btn");
  const plateContainer = document.getElementById("plate-container");
  const resetFiltersBtn = document.getElementById("reset-filters-btn");
  const filterStatus = document.getElementById("filter-status");
  const filterPanel = document.getElementById("filter-panel");
  const activeFiltersDisplay = document.getElementById("active-filters");

  // Axis display labels with endpoints
  const axisLabels = {
    heat: { name: "Heat", min: "mild", max: "spicy" },
    sweet: { name: "Sweet", min: "bitter", max: "sweet" },
    zest: { name: "Zest", min: "subtle", max: "bold" },
    heft: { name: "Heft", min: "light", max: "hearty" },
  };

  const categoryDescriptions = {
    "side-dishes": "Something to know about",
    desserts: "Something sweet",
    "plates-cutlery": "Historical context",
    drinks: "Something to thirst for",
  };

  const categoryLabels = {
    "side-dishes": "side dish",
    desserts: "dessert",
    "plates-cutlery": "plates & cutlery",
    drinks: "drink",
  };

  // ============================================
  // Rendering Functions
  // ============================================

  function truncateDescription(desc, maxLength = 150) {
    if (desc.length <= maxLength) return desc;
    return desc.slice(0, maxLength) + "...";
  }

  function createTagPill(tag) {
    return `<span class="tag-pill tag-pill--sm">${tag}</span>`;
  }

  function createIcon(icon) {
    if (!icon) return "";
    return `
      <div class="potluck-icon potluck-icon--md" 
           style="--icon-primary: ${icon.primaryColor}; --icon-secondary: ${icon.secondaryColor};"
           aria-hidden="true">
        <span class="potluck-icon__placeholder">${icon.svg}</span>
      </div>
    `;
  }

  function createCard(item, category) {
    if (!item) {
      return `
        <div class="potluck-grid__empty">
          <p class="text-body-large">No items in this category yet.</p>
        </div>
      `;
    }

    const href = `/${category}/${item.slug}/`;
    const tags = item.tags
      .slice(0, 4)
      .map((tag) => createTagPill(tag))
      .join("");

    return `
      <a href="${href}" class="potluck-card-link" aria-label="Read more about ${item.title}">
        <article class="potluck-card">
          <div class="potluck-card__header">
            ${createIcon(item.icon)}
            <h3 class="potluck-card__title">${item.title}</h3>
          </div>
          <p class="potluck-card__description">${truncateDescription(item.description)}</p>
          ${tags ? `<div class="potluck-card__tags">${tags}</div>` : ""}
        </article>
      </a>
    `;
  }

  function createPlateItem(item, category, isApproximate = false) {
    const approximateIndicator = isApproximate
      ? `<span class="approximate-indicator" title="Closest match to your filters">~</span>`
      : "";

    return `
      <div class="plate-display__item ${isApproximate ? "plate-display__item--approximate" : ""}">
        <div class="plate-display__category-row">
          <a href="/${category}/" class="category-badge category-badge--link">${categoryLabels[category]}${approximateIndicator}</a>
          <span class="plate-display__category-description">${categoryDescriptions[category]}</span>
        </div>
        ${createCard(item, category)}
      </div>
    `;
  }

  function renderPlate() {
    const sideDishResult = getFilteredRandomItem(allItems.sideDishes);
    const dessertResult = getFilteredRandomItem(allItems.desserts);
    const platesCutleryResult = getFilteredRandomItem(allItems.platesCutlery);
    const drinkResult = getFilteredRandomItem(allItems.drinks);

    const hasApproximate =
      !sideDishResult?.exact ||
      !dessertResult?.exact ||
      !platesCutleryResult?.exact ||
      !drinkResult?.exact;

    plateContainer.innerHTML = `
      <div class="plate-display">
        ${createPlateItem(sideDishResult?.item, "side-dishes", !sideDishResult?.exact)}
        ${createPlateItem(dessertResult?.item, "desserts", !dessertResult?.exact)}
        ${createPlateItem(platesCutleryResult?.item, "plates-cutlery", !platesCutleryResult?.exact)}
        ${createPlateItem(drinkResult?.item, "drinks", !drinkResult?.exact)}
      </div>
    `;

    // Update filter status
    if (hasActiveFilters()) {
      if (hasApproximate) {
        filterStatus.textContent =
          "Some items are approximate matches (marked with ~)";
        filterStatus.classList.add("filter-status--visible");
      } else {
        filterStatus.textContent = "All items match your flavor profile";
        filterStatus.classList.add("filter-status--visible");
      }
    } else {
      filterStatus.textContent = "";
      filterStatus.classList.remove("filter-status--visible");
    }
  }

  // ============================================
  // Range Slider Handling
  // ============================================

  function initializeSliders() {
    const sliders = document.querySelectorAll("[data-range-slider]");

    sliders.forEach((slider) => {
      const axis = slider.dataset.axis;
      const minInput = slider.querySelector("[data-min-input]");
      const maxInput = slider.querySelector("[data-max-input]");
      const rangeFill = slider.querySelector("[data-range-fill]");
      const valueDisplay = slider.querySelector("[data-value-display]");
      const ticks = slider.querySelectorAll("[data-tick]");

      // Initialize with current filter values
      minInput.value = filters[axis][0];
      maxInput.value = filters[axis][1];

      function updateSlider() {
        let minVal = parseInt(minInput.value);
        let maxVal = parseInt(maxInput.value);

        // Prevent min from exceeding max
        if (minVal > maxVal) {
          if (this === minInput) {
            minVal = maxVal;
            minInput.value = minVal;
          } else {
            maxVal = minVal;
            maxInput.value = maxVal;
          }
        }

        // Update filter state
        filters[axis] = [minVal, maxVal];
        userSetFilters.add(axis);

        // Update visual range fill
        const min = parseInt(minInput.min);
        const max = parseInt(minInput.max);
        const leftPercent = ((minVal - min) / (max - min)) * 100;
        const rightPercent = ((max - maxVal) / (max - min)) * 100;
        rangeFill.style.left = `${leftPercent}%`;
        rangeFill.style.right = `${rightPercent}%`;

        // Update value display
        if (minVal === 1 && maxVal === 5) {
          valueDisplay.textContent = "all";
        } else if (minVal === maxVal) {
          valueDisplay.textContent = minVal;
        } else {
          valueDisplay.textContent = `${minVal}-${maxVal}`;
        }

        // Update tick highlights
        ticks.forEach((tick) => {
          const tickVal = parseInt(tick.dataset.tick);
          tick.dataset.inRange = tickVal >= minVal && tickVal <= maxVal;
        });

        // Sync to URL and update active filters display
        syncFiltersToURL();
        updateActiveFiltersDisplay();
      }

      minInput.addEventListener("input", updateSlider);
      maxInput.addEventListener("input", updateSlider);

      // Initialize visual state
      updateSlider.call(minInput);
    });
  }

  function resetAllFilters() {
    for (const axis of FLAVOR_AXES) {
      filters[axis] = [...DEFAULT_RANGE];
    }
    userSetFilters.clear();

    // Reset slider UI
    const sliders = document.querySelectorAll("[data-range-slider]");
    sliders.forEach((slider) => {
      const minInput = slider.querySelector("[data-min-input]");
      const maxInput = slider.querySelector("[data-max-input]");
      const rangeFill = slider.querySelector("[data-range-fill]");
      const valueDisplay = slider.querySelector("[data-value-display]");
      const ticks = slider.querySelectorAll("[data-tick]");

      minInput.value = 1;
      maxInput.value = 5;
      rangeFill.style.left = "0%";
      rangeFill.style.right = "0%";
      valueDisplay.textContent = "all";

      ticks.forEach((tick) => {
        tick.dataset.inRange = "true";
      });
    });

    syncFiltersToURL();
    filterStatus.textContent = "";
    filterStatus.classList.remove("filter-status--visible");
    updateActiveFiltersDisplay();
  }

  // ============================================
  // Event Listeners
  // ============================================

  newPlateBtn.addEventListener("click", () => {
    // Add a subtle animation
    plateContainer.style.opacity = "0.5";
    plateContainer.style.transform = "scale(0.98)";

    setTimeout(() => {
      renderPlate();
      plateContainer.style.opacity = "1";
      plateContainer.style.transform = "scale(1)";
    }, 150);
  });

  resetFiltersBtn.addEventListener("click", resetAllFilters);

  // ============================================
  // Initialize
  // ============================================

  // Load filters from URL on page load
  loadFiltersFromURL();

  // If filters were loaded from URL, open the filter panel
  if (userSetFilters.size > 0) {
    filterPanel.open = true;
  }

  // Initialize slider UI
  initializeSliders();

  // Update active filters display
  updateActiveFiltersDisplay();
</script>

<style>
  .plate-page {
    min-height: 80vh;
  }

  .plate-header {
    margin-bottom: var(--spacing-xl);
  }

  .plate-description {
    max-width: 600px;
  }

  /* Filter Controls Container */
  .filter-controls {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  /* Filter Panel */
  .filter-panel {
    margin-bottom: var(--spacing-xl);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
    background-color: var(--secondary-lightest);
  }

  .filter-panel__toggle {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-md) var(--spacing-lg);
    cursor: pointer;
    user-select: none;
    font-weight: var(--font-weight-medium);
    color: var(--text-color-default);
    list-style: none;
  }

  .filter-panel__toggle::-webkit-details-marker {
    display: none;
  }

  .filter-panel__toggle:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: var(--radius-md);
  }

  .filter-panel__toggle-indicator {
    width: 0.5rem;
    height: 0.5rem;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
    transition: transform var(--transition-fast);
  }

  .filter-panel[open] .filter-panel__toggle-indicator {
    transform: rotate(-135deg);
  }

  .filter-panel__content {
    padding: 0 var(--spacing-lg) var(--spacing-lg);
  }

  .filter-panel__sliders {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--spacing-md);
  }

  .filter-panel__actions {
    display: flex;
    justify-content: flex-end;
    margin-top: var(--spacing-md);
  }

  /* Active Filters Display */
  .active-filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-md);
    visibility: hidden;
    opacity: 0;
    transition:
      opacity var(--transition-normal),
      visibility var(--transition-normal);
    min-height: 1.5rem; /* Reserve space to prevent layout shift */
  }

  .active-filters--visible {
    visibility: visible;
    opacity: 1;
  }

  .active-filters__label {
    font-size: var(--font-size-sm);
    color: var(--text-color-lighter);
    font-weight: var(--font-weight-medium);
  }

  .active-filters__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-md);
  }

  :global(.filter-pill) {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    background-color: var(--secondary-lightest);
    color: var(--secondary-dark);
    padding: var(--spacing-xs) var(--spacing-md);
    border: 1px solid var(--secondary-lighter);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    white-space: nowrap;
    margin-right: var(--spacing-md);
  }

  :global(.filter-pill:last-child) {
    margin-right: 0;
  }

  :global(.filter-pill__name),
  :global(.filter-pill__value) {
    margin: 0;
    display: inline;
  }

  :global(.filter-pill__name) {
    font-weight: var(--font-weight-medium);
  }

  :global(.filter-pill__name)::after {
    content: " ";
  }

  :global(.filter-pill__value) {
    font-variant-numeric: tabular-nums;
    opacity: 0.8;
    font-weight: var(--font-weight-medium);
  }

  /* Mobile: Stack active filters above filter panel */
  @media (max-width: 767px) {
    .filter-controls {
      flex-direction: column;
    }

    .active-filters {
      order: -1;
    }

    .filter-panel {
      order: 0;
    }
  }

  /* Plate Actions */
  .plate-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  .filter-status {
    font-size: var(--font-size-sm);
    color: var(--text-color-lighter);
    font-style: italic;
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .filter-status--visible {
    opacity: 1;
  }

  /* Button variants */
  .button-secondary {
    background-color: transparent;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-medium);
