---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import ActiveFilters from "@/components/filters/ActiveFilters.svelte";
import FilterPanel from "@/components/filters/FilterPanel.svelte";
import RandomPlate from "@/components/potluck/RandomPlate.svelte";
import { collectionEntryToItem } from "@/lib/filters";

// Fetch all collections and map to PotluckItem format
const sideDishes = (await getCollection("side-dishes")).map(collectionEntryToItem);
const desserts = (await getCollection("desserts")).map(collectionEntryToItem);
const platesCutlery = (await getCollection("plates-cutlery")).map(collectionEntryToItem);
const drinks = (await getCollection("drinks")).map(collectionEntryToItem);
---

<Layout
  title="Your Plate"
  description="A random selection of resources from the Baltimore ICE Potluck - one side dish, one dessert, some plates & cutlery, and a drink."
>
  <section class="plate-page section-padding">
    <div class="container-content">
      <header class="plate-header">
        <h1 class="text-heading-1">Your Plate</h1>
        <div class="title-accent"></div>
        <p class="text-body-large plate-description">
          Here's a random selection from the potluck—one resource from each
          category. Use the flavor sliders to adjust what kind of resources
          you're looking for, then click the button to get a new combination.
        </p>
      </header>

      <div class="filter-controls">
        <ActiveFilters client:load />
        <FilterPanel client:load />
      </div>

      <RandomPlate
        {sideDishes}
        {desserts}
        {platesCutlery}
        {drinks}
        client:load
      />

      <div class="plate-footer">
        <p class="text-body">
          Want to explore more? Browse all resources in each category:
        </p>
        <nav class="category-links">
          <a href="/side-dishes/" class="category-link">Side Dishes</a>
          <a href="/desserts/" class="category-link">Desserts</a>
          <a href="/plates-cutlery/" class="category-link">Plates & Cutlery</a>
          <a href="/drinks/" class="category-link">Drinks</a>
        </nav>
      </div>
    </div>
  </section>
</Layout>

<style>
  .plate-page {
    min-height: 80vh;
  }

  .plate-header {
    margin-bottom: var(--spacing-xl);
  }

  .plate-description {
    max-width: 600px;
  }

  .filter-controls {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  .plate-footer {
    margin-top: var(--spacing-3xl);
    padding-top: var(--spacing-xl);
    border-top: var(--border-width) solid var(--border-default);
  }

  .category-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
    margin-top: var(--spacing-md);
  }

  .category-link {
    display: inline-flex;
    align-items: center;
    padding: var(--spacing-sm) var(--spacing-md);
    background-color: var(--secondary-lightest);
    color: var(--secondary-dark);
    border-radius: var(--radius-md);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    transition:
      background-color var(--transition-normal),
      color var(--transition-normal);
  }

  .category-link:hover {
    background-color: var(--secondary-lighter);
    color: var(--secondary-darkest);
  }

  .category-link:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
