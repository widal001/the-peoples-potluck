---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Banner from "@/components/sections/Banner.astro";
import PotluckScrollSection from "@/components/potluck/PotluckScrollSection.astro";
import { siteConfig } from "@/config/site";
import { COLLECTIONS } from "@/config/collections";

// Fetch all collections
const settings = await getCollection("settings");
const dishes = await getCollection("dishes");
const desserts = await getCollection("desserts");
const drinks = await getCollection("drinks");
const bites = await getCollection("bites");

// Sort each by addedDate, newest first
const sortByDate = <T extends { data: { addedDate?: string } }>(items: T[]) =>
  items.sort((a, b) => {
    const dateA = a.data.addedDate ? new Date(a.data.addedDate).getTime() : 0;
    const dateB = b.data.addedDate ? new Date(b.data.addedDate).getTime() : 0;
    return dateB - dateA;
  });

const sortedSettings = sortByDate(settings);
const sortedDishes = sortByDate(dishes);
const sortedDesserts = sortByDate(desserts);
const sortedDrinks = sortByDate(drinks);
const sortedBites = sortByDate(bites);

const bannerInfo = {
  tagline: "Come find your place at the table",
  description:
    "A community resource potluck for solidarity with immigrants in Baltimore. Browse our collection of resources, historical context, and ideas—or have a plate made for you with a random selection from each category.",
  ctaText: "Make me a plate",
  ctaHref: "/plate/",
};

// Use centralized config for category metadata
const c = COLLECTIONS;
---

<Layout title={siteConfig.companyName} description={bannerInfo.tagline}>
  <Banner
    tagline={bannerInfo.tagline}
    description={bannerInfo.description}
    ctaText={bannerInfo.ctaText}
    ctaHref={bannerInfo.ctaHref}
  />

  <!-- Table Settings Section -->
  <PotluckScrollSection
    title={c.settings.label}
    description={c.settings.description}
    items={sortedSettings}
    category="settings"
    viewAllHref={c.settings.path}
    maxItems={5}
  />

  <!-- Dishes Section -->
  <PotluckScrollSection
    title={c.dishes.label}
    description={c.dishes.description}
    items={sortedDishes}
    category="dishes"
    viewAllHref={c.dishes.path}
    maxItems={5}
  />

  <!-- Desserts Section -->
  <PotluckScrollSection
    title={c.desserts.label}
    description={c.desserts.description}
    items={sortedDesserts}
    category="desserts"
    viewAllHref={c.desserts.path}
    maxItems={5}
  />

  <!-- Drinks Section -->
  <PotluckScrollSection
    title={c.drinks.label}
    description={c.drinks.description}
    items={sortedDrinks}
    category="drinks"
    viewAllHref={c.drinks.path}
    maxItems={5}
  />

  <!-- Sips & Bites Section -->
  <PotluckScrollSection
    title={c.bites.label}
    description={c.bites.description}
    items={sortedBites}
    category="bites"
    viewAllHref={c.bites.path}
    maxItems={5}
  />

  <div class="footer-spacer"></div>
</Layout>

<style>
  .footer-spacer {
    height: var(--spacing-xl);
  }
</style>
