---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Banner from "@/components/sections/Banner.astro";
import PotluckScrollSection from "@/components/potluck/PotluckScrollSection.astro";
import { siteConfig } from "@/config/site";

// Fetch all collections
const settings = await getCollection("settings");
const dishes = await getCollection("dishes");
const desserts = await getCollection("desserts");
const drinks = await getCollection("drinks");
const bites = await getCollection("bites");

// Sort each by addedDate, newest first
const sortByDate = <T extends { data: { addedDate?: string } }>(items: T[]) =>
  items.sort((a, b) => {
    const dateA = a.data.addedDate ? new Date(a.data.addedDate).getTime() : 0;
    const dateB = b.data.addedDate ? new Date(b.data.addedDate).getTime() : 0;
    return dateB - dateA;
  });

const sortedSettings = sortByDate(settings);
const sortedDishes = sortByDate(dishes);
const sortedDesserts = sortByDate(desserts);
const sortedDrinks = sortByDate(drinks);
const sortedBites = sortByDate(bites);

const bannerInfo = {
  tagline: "Come find your place at the table",
  description:
    "A community resource potluck for solidarity with immigrants in Baltimore. Browse our collection of resources, historical context, and ideas—or have a plate made for you with a random selection from each category.",
  ctaText: "Make me a plate",
  ctaHref: "/plate/",
};

// Category descriptions
const categoryInfo = {
  settings: {
    title: "Table Settings",
    description:
      "Understand the landscape. History, legislation, and local context.",
    href: "/settings/",
  },
  dishes: {
    title: "Dishes",
    description:
      "Find your people. Organizations, coalitions, and initiatives doing the work.",
    href: "/dishes/",
  },
  desserts: {
    title: "Desserts",
    description:
      "See what's possible. Successes, case studies, and stories of community power.",
    href: "/desserts/",
  },
  drinks: {
    title: "Drinks",
    description:
      "Name what's missing. Gaps, needs, and ideas waiting for support.",
    href: "/drinks/",
  },
  bites: {
    title: "Sips & Bites",
    description:
      "Do something today. Specific ways to get involved based on your skills.",
    href: "/bites/",
  },
};
---

<Layout title={siteConfig.companyName} description={bannerInfo.tagline}>
  <Banner
    tagline={bannerInfo.tagline}
    description={bannerInfo.description}
    ctaText={bannerInfo.ctaText}
    ctaHref={bannerInfo.ctaHref}
  />

  <!-- Table Settings Section -->
  <PotluckScrollSection
    title={categoryInfo.settings.title}
    description={categoryInfo.settings.description}
    items={sortedSettings}
    category="settings"
    viewAllHref={categoryInfo.settings.href}
    maxItems={5}
  />

  <!-- Dishes Section -->
  <PotluckScrollSection
    title={categoryInfo.dishes.title}
    description={categoryInfo.dishes.description}
    items={sortedDishes}
    category="dishes"
    viewAllHref={categoryInfo.dishes.href}
    maxItems={5}
  />

  <!-- Desserts Section -->
  <PotluckScrollSection
    title={categoryInfo.desserts.title}
    description={categoryInfo.desserts.description}
    items={sortedDesserts}
    category="desserts"
    viewAllHref={categoryInfo.desserts.href}
    maxItems={5}
  />

  <!-- Drinks Section -->
  <PotluckScrollSection
    title={categoryInfo.drinks.title}
    description={categoryInfo.drinks.description}
    items={sortedDrinks}
    category="drinks"
    viewAllHref={categoryInfo.drinks.href}
    maxItems={5}
  />

  <!-- Sips & Bites Section -->
  <PotluckScrollSection
    title={categoryInfo.bites.title}
    description={categoryInfo.bites.description}
    items={sortedBites}
    category="bites"
    viewAllHref={categoryInfo.bites.href}
    maxItems={5}
  />

  <div class="footer-spacer"></div>
</Layout>

<style>
  .footer-spacer {
    height: var(--spacing-xl);
  }
</style>
